<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.graduate.framework.mapper.ShopMapper">
    <resultMap id="ShopResult" type="com.graduate.framework.entity.Shop">
        <id property="id" column="id"/>
        <result property="listDate" column="listDate"/>
        <result property="traceCode" column="traceCode"/>
        <result property="amount" column="amount"/>
        <result property="sendDate" column="sendDate"/>
        <result property="price" column="price"/>
        <result property="origin" column="origin"/>
        <result property="name" column="name"/>
        <result property="recvDate" column="recvDate"/>
        <result property="productId" column="productId"/>
    </resultMap>

    <select id="findAll" resultMap="ShopResult">
        SELECT * FROM shop
    </select>

    <select id="findById" resultMap="ShopResult">
        SELECT * FROM shop WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.graduate.framework.entity.Shop">
        INSERT INTO shop (id, listDate, traceCode, amount, sendDate, price, origin, name, recvDate, productId)
        VALUES (#{id}, #{listDate}, #{traceCode}, #{amount}, #{sendDate}, #{price}, #{origin}, #{name}, #{recvDate}, #{productId})
    </insert>

    <update id="update" parameterType="com.graduate.framework.entity.Shop">
        UPDATE shop SET
            listDate = #{listDate},
            traceCode = #{traceCode},
            amount = #{amount},
            sendDate = #{sendDate},
            price = #{price},
            origin = #{origin},
            name = #{name},
            recvDate = #{recvDate},
            productId = #{productId}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM shop WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM shop WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="findByProductName" resultMap="ShopResult">
        SELECT * FROM shop WHERE name = #{name}
    </select>

    <select id="findByTraceCode" resultMap="ShopResult">
        SELECT * FROM shop WHERE traceCode = #{traceCode}
    </select>
</mapper>
